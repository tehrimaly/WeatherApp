# Copy this to .env and fill in real values
PORT=5000
NODE_ENV=development

# MongoDB connection (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/weatherapp
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/weatherapp

# OpenWeatherMap API Key (free at openweathermap.org)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# YouTube Data API v3 Key (optional - for video enrichment)
# Get at: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
